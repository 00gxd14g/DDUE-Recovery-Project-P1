<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="PyDDEU.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PyDDEU.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="ShellGradientStartColor">#FFF3F8FB</Color>
                    <Color x:Key="ShellGradientEndColor">#FFE9EEF7</Color>
                    <Color x:Key="ShellCardColor">#F8FFFFFF</Color>
                    <Color x:Key="ShellCardBorderColor">#1F0B3550</Color>
                    <Color x:Key="ShellAccentColor">#FF0E7490</Color>
                    <Color x:Key="ShellAccentMutedColor">#1A0E7490</Color>
                    <Color x:Key="ShellTextMutedColor">#CC1F2937</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="ShellGradientStartColor">#FF0D1722</Color>
                    <Color x:Key="ShellGradientEndColor">#FF10131A</Color>
                    <Color x:Key="ShellCardColor">#1AFFFFFF</Color>
                    <Color x:Key="ShellCardBorderColor">#33FFFFFF</Color>
                    <Color x:Key="ShellAccentColor">#FF38BDF8</Color>
                    <Color x:Key="ShellAccentMutedColor">#2638BDF8</Color>
                    <Color x:Key="ShellTextMutedColor">#CCF3F4F6</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast" />
            </ResourceDictionary.ThemeDictionaries>

            <LinearGradientBrush x:Key="ShellPageBackgroundBrush" EndPoint="1,1" StartPoint="0,0">
                <GradientStop Color="{ThemeResource ShellGradientStartColor}" Offset="0" />
                <GradientStop Color="{ThemeResource ShellGradientEndColor}" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="ShellCardBrush" Color="{ThemeResource ShellCardColor}" />
            <SolidColorBrush x:Key="ShellCardBorderBrush" Color="{ThemeResource ShellCardBorderColor}" />
            <SolidColorBrush x:Key="ShellAccentBrush" Color="{ThemeResource ShellAccentColor}" />
            <SolidColorBrush x:Key="ShellAccentMutedBrush" Color="{ThemeResource ShellAccentMutedColor}" />
            <SolidColorBrush x:Key="ShellTextMutedBrush" Color="{ThemeResource ShellTextMutedColor}" />

            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>

            <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Opacity" Value="0.86" />
            </Style>

            <Style x:Key="SectionCardStyle" TargetType="Border">
                <Setter Property="Padding" Value="12" />
                <Setter Property="Background" Value="{ThemeResource ShellCardBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ShellCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="14" />
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="SectionMetaStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground"
                        Value="{ThemeResource ShellTextMutedBrush}" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource ShellAccentBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>

            <Style x:Key="InputButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
