<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PyDDEU.WinUI.Views.MainPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PyDDEU.WinUI.Models"
    xmlns:views="using:PyDDEU.WinUI.Views"
    Loaded="OnPageLoaded"
    Unloaded="OnPageUnloaded"
    Background="{ThemeResource ShellPageBackgroundBrush}"
    mc:Ignorable="d">

    <Grid x:Name="LayoutRoot" Padding="20" RowSpacing="12">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="24" IsStaggeringEnabled="True" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1200" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="PathCol0.Width" Value="*" />
                        <Setter Target="PathCol1.Width" Value="*" />
                        <Setter Target="PathRow0.Height" Value="Auto" />
                        <Setter Target="PathRow1.Height" Value="0" />
                        <Setter Target="SourceInputContainer.(Grid.Column)" Value="0" />
                        <Setter Target="SourceInputContainer.(Grid.Row)" Value="0" />
                        <Setter Target="OutputInputContainer.(Grid.Column)" Value="1" />
                        <Setter Target="OutputInputContainer.(Grid.Row)" Value="0" />

                        <Setter Target="WorkspaceCol0.Width" Value="1.1*" />
                        <Setter Target="WorkspaceCol1.Width" Value="1.2*" />
                        <Setter Target="WorkspaceCol2.Width" Value="2*" />
                        <Setter Target="WorkspaceRow0.Height" Value="*" />
                        <Setter Target="WorkspaceRow1.Height" Value="0" />
                        <Setter Target="WorkspaceRow2.Height" Value="0" />
                        <Setter Target="DisksPanel.(Grid.Column)" Value="0" />
                        <Setter Target="DisksPanel.(Grid.Row)" Value="0" />
                        <Setter Target="DisksPanel.(Grid.ColumnSpan)" Value="1" />
                        <Setter Target="PartitionsPanel.(Grid.Column)" Value="1" />
                        <Setter Target="PartitionsPanel.(Grid.Row)" Value="0" />
                        <Setter Target="PartitionsPanel.(Grid.ColumnSpan)" Value="1" />
                        <Setter Target="FilesPanel.(Grid.Column)" Value="2" />
                        <Setter Target="FilesPanel.(Grid.Row)" Value="0" />
                        <Setter Target="FilesPanel.(Grid.ColumnSpan)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="CompactState">
                    <VisualState.Setters>
                        <Setter Target="PathCol0.Width" Value="*" />
                        <Setter Target="PathCol1.Width" Value="0" />
                        <Setter Target="PathRow0.Height" Value="Auto" />
                        <Setter Target="PathRow1.Height" Value="Auto" />
                        <Setter Target="SourceInputContainer.(Grid.Column)" Value="0" />
                        <Setter Target="SourceInputContainer.(Grid.Row)" Value="0" />
                        <Setter Target="OutputInputContainer.(Grid.Column)" Value="0" />
                        <Setter Target="OutputInputContainer.(Grid.Row)" Value="1" />

                        <Setter Target="WorkspaceCol0.Width" Value="*" />
                        <Setter Target="WorkspaceCol1.Width" Value="0" />
                        <Setter Target="WorkspaceCol2.Width" Value="0" />
                        <Setter Target="WorkspaceRow0.Height" Value="*" />
                        <Setter Target="WorkspaceRow1.Height" Value="*" />
                        <Setter Target="WorkspaceRow2.Height" Value="*" />
                        <Setter Target="DisksPanel.(Grid.Column)" Value="0" />
                        <Setter Target="DisksPanel.(Grid.Row)" Value="0" />
                        <Setter Target="DisksPanel.(Grid.ColumnSpan)" Value="1" />
                        <Setter Target="PartitionsPanel.(Grid.Column)" Value="0" />
                        <Setter Target="PartitionsPanel.(Grid.Row)" Value="1" />
                        <Setter Target="PartitionsPanel.(Grid.ColumnSpan)" Value="1" />
                        <Setter Target="FilesPanel.(Grid.Column)" Value="0" />
                        <Setter Target="FilesPanel.(Grid.Row)" Value="2" />
                        <Setter Target="FilesPanel.(Grid.ColumnSpan)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Admin warning -->
        <InfoBar x:Name="AdminWarningBar" Grid.Row="0"
                 IsClosable="True" IsOpen="False"
                 Severity="Warning"
                 Title="Not running as Administrator"
                 Message="Raw disk access (\\.\PhysicalDriveN) requires elevated privileges. Run as Administrator for full functionality."
                 Margin="0,0,0,4" />

        <!-- Row 1: Title bar -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="2">
                <TextBlock Style="{StaticResource PageTitleStyle}" Text="PyDDEU Recovery" />
                <TextBlock Style="{StaticResource PageSubtitleStyle}"
                           Text="Forensic disk analysis, recovery &amp; imaging console" />
            </StackPanel>
            <Border Grid.Column="1" Padding="14,8"
                    Background="{ThemeResource ShellAccentMutedBrush}"
                    CornerRadius="12" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ProgressRing Height="16" Width="16" IsActive="{Binding IsBusy}" />
                    <TextBlock MaxWidth="380" Text="{Binding StatusText}"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 2: Command bar -->
        <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
            <CommandBar Background="Transparent" DefaultLabelPosition="Right"
                        IsDynamicOverflowEnabled="True" OverflowButtonVisibility="Auto">
                <AppBarButton x:Name="ListDisksButton" Click="OnListDisksClicked"
                              Icon="Refresh" IsEnabled="{Binding CommandsEnabled}" Label="List Disks" />
                <AppBarButton x:Name="ConnectDiskButton" Click="OnConnectClicked"
                              Icon="Plug" IsEnabled="{Binding CommandsEnabled}" Label="Connect Disk" />
                <AppBarButton x:Name="ScanPartitionsButton" Click="OnScanPartitionsClicked"
                              Icon="Find" IsEnabled="{Binding CommandsEnabled}" Label="Scan Partitions" />
                <AppBarButton x:Name="DeepScanButton" Click="OnDeepScanClicked"
                              Icon="Library" IsEnabled="{Binding CommandsEnabled}" Label="Deep Scan" />
                <AppBarButton x:Name="MftScanButton" Click="OnMftScanClicked"
                              Icon="Filter" IsEnabled="{Binding CommandsEnabled}" Label="MFT Scan" />
                <AppBarButton x:Name="ParseFsButton" Click="OnParseFsClicked"
                              Icon="OpenFile" IsEnabled="{Binding CommandsEnabled}" Label="Browse FS" />
                <AppBarButton x:Name="RecoverSelectedButton" Click="OnRecoverSelectedClicked"
                              Icon="Save" IsEnabled="{Binding CommandsEnabled}" Label="Recover" />
                <AppBarButton x:Name="RecoverAllButton" Click="OnRecoverAllClicked"
                              Icon="SaveLocal" IsEnabled="{Binding CommandsEnabled}" Label="Recover All" />
                <AppBarButton x:Name="StopButton" Click="OnStopClicked"
                              Icon="Stop" IsEnabled="{Binding CanStop}" Label="Stop" />
                <CommandBar.SecondaryCommands>
                    <AppBarButton x:Name="ExportAllButton" Click="OnExportAllClicked"
                                  Icon="Download" IsEnabled="{Binding CommandsEnabled}" Label="Export All" />
                    <AppBarButton x:Name="FileCarveButton" Click="OnFileCarveClicked"
                                  Icon="Find" IsEnabled="{Binding CommandsEnabled}" Label="File Carve" />
                    <AppBarButton x:Name="CreateImageButton" Click="OnCreateImageClicked"
                                  Icon="SaveLocal" IsEnabled="{Binding CommandsEnabled}" Label="Create Image" />
                    <AppBarButton x:Name="ClearLogsButton" Click="OnClearLogsClicked"
                                  Icon="Clear" Label="Clear Logs" />
                </CommandBar.SecondaryCommands>
            </CommandBar>
        </Border>

        <!-- Row 3: Source/output paths + options -->
        <Border Grid.Row="3" Style="{StaticResource SectionCardStyle}">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="PathsGrid" ColumnSpacing="12" Grid.Row="0" RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="PathCol0" Width="*" />
                        <ColumnDefinition x:Name="PathCol1" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="PathRow0" Height="Auto" />
                        <RowDefinition x:Name="PathRow1" Height="0" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="SourceInputContainer" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Header="Source" IsEnabled="{Binding CommandsEnabled}"
                                 PlaceholderText="\\.\PhysicalDrive0 or C:\Evidence\disk.img"
                                 Text="{Binding SourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Click="OnPickSourceClicked" Content="Browse"
                                IsEnabled="{Binding CommandsEnabled}"
                                Style="{StaticResource InputButtonStyle}" VerticalAlignment="Bottom" />
                    </Grid>

                    <Grid x:Name="OutputInputContainer" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Header="Output Folder" IsEnabled="{Binding CommandsEnabled}"
                                 PlaceholderText="C:\Recovered"
                                 Text="{Binding OutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Click="OnPickOutputFolderClicked" Content="Browse"
                                IsEnabled="{Binding CommandsEnabled}"
                                Style="{StaticResource InputButtonStyle}" VerticalAlignment="Bottom" />
                    </Grid>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="240" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <CheckBox Content="Include Deleted" IsChecked="{Binding IncludeDeleted, Mode=TwoWay}"
                                  IsEnabled="{Binding CommandsEnabled}" />
                        <CheckBox Content="Include Active" IsChecked="{Binding IncludeActive, Mode=TwoWay}"
                                  IsEnabled="{Binding CommandsEnabled}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <CheckBox Content="Aggressive Partition Scan"
                                  IsChecked="{Binding AggressivePartitionScan, Mode=TwoWay}"
                                  IsEnabled="{Binding CommandsEnabled}" />
                        <CheckBox Content="Image Selected Partition"
                                  IsChecked="{Binding ImageSelectedPartitionOnly, Mode=TwoWay}"
                                  IsEnabled="{Binding CommandsEnabled}" />
                    </StackPanel>
                    <NumberBox Grid.Column="2" Header="Max Records" IsEnabled="{Binding CommandsEnabled}"
                               Maximum="500000" Minimum="100" SmallChange="1000"
                               SpinButtonPlacementMode="Compact"
                               Value="{Binding MaxRecords, Mode=TwoWay}" />
                    <TextBox Grid.Column="3" Header="Export Extensions"
                             IsEnabled="{Binding CommandsEnabled}"
                             PlaceholderText="jpg,pdf,docx"
                             Text="{Binding ExportExtensions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Grid>
        </Border>

        <!-- Row 4: Main workspace -->
        <Grid Grid.Row="4" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="2.4*" />
                <RowDefinition Height="1.2*" />
            </Grid.RowDefinitions>

            <!-- Panels: Disks / Partitions / Files -->
            <Grid x:Name="WorkspaceGrid" Grid.Row="0" ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="WorkspaceCol0" Width="1.1*" />
                    <ColumnDefinition x:Name="WorkspaceCol1" Width="1.2*" />
                    <ColumnDefinition x:Name="WorkspaceCol2" Width="2*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="WorkspaceRow0" Height="*" />
                    <RowDefinition x:Name="WorkspaceRow1" Height="0" />
                    <RowDefinition x:Name="WorkspaceRow2" Height="0" />
                </Grid.RowDefinitions>

                <!-- Disks -->
                <Border x:Name="DisksPanel" Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Disks" />
                            <TextBlock Grid.Column="1" Style="{StaticResource SectionMetaStyle}"
                                       Text="{Binding DiskCount}" />
                        </Grid>
                        <ListView x:Name="DisksListView" Grid.Row="1"
                                  ItemsSource="{Binding Disks}"
                                  SelectedItem="{Binding SelectedDisk, Mode=TwoWay}"
                                  SelectionChanged="OnDisksSelectionChanged"
                                  SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="2" Padding="2">
                                        <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="13"
                                                   Text="{Binding Path}" />
                                        <TextBlock FontSize="12" Opacity="0.7"
                                                   Text="{Binding DisplayText}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Partitions -->
                <Border x:Name="PartitionsPanel" Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Partitions" />
                            <TextBlock Grid.Column="1" Style="{StaticResource SectionMetaStyle}"
                                       Text="{Binding PartitionCount}" />
                        </Grid>
                        <ListView x:Name="PartitionsListView" Grid.Row="1"
                                  ItemsSource="{Binding Partitions}"
                                  SelectedItem="{Binding SelectedPartition, Mode=TwoWay}"
                                  SelectionChanged="OnPartitionsSelectionChanged"
                                  SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="2" Padding="2">
                                        <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="13"
                                                   Text="{Binding DisplayText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="12" Opacity="0.7"
                                                   Text="{Binding SizeText}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Files -->
                <Border x:Name="FilesPanel" Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Files" />
                                <TextBlock x:Name="FileSelectionText" Style="{StaticResource SectionMetaStyle}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Style="{StaticResource SectionMetaStyle}"
                                       Text="{Binding FileCount}" />
                        </Grid>
                        <TreeView x:Name="FilesTreeView" Grid.Row="1"
                                  SelectionMode="Multiple"
                                  ItemInvoked="OnFileTreeItemInvoked" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Log panel -->
            <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Operation Log" />
                        <Button Grid.Column="1" Click="OnClearLogsClicked" Content="Clear"
                                Style="{StaticResource InputButtonStyle}" />
                    </Grid>
                    <ListView x:Name="LogsListView" Grid.Row="1"
                              ItemsSource="{Binding Logs}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                           Text="{Binding DisplayText}"
                                           TextWrapping="WrapWholeWords" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 5: Status / progress bar -->
        <Border Grid.Row="5" Style="{StaticResource SectionCardStyle}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="60" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" FontSize="13" />
                <ProgressBar Grid.Column="1" Height="6"
                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                             Maximum="100" Minimum="0"
                             Value="{Binding ProgressValue}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" HorizontalAlignment="Right"
                           Text="{Binding ProgressText}" VerticalAlignment="Center"
                           FontSize="13" Opacity="0.8" />
            </Grid>
        </Border>
    </Grid>
</Page>
